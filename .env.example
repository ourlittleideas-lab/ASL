# ── Supabase ──────────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe to expose in client-side code)
SUPABASE_ANON_KEY=your-anon-key-here

# ── GODMODE ───────────────────────────────────────────────────
# Passcode for the reserved GODMODE account.
# Stored only on the server — verified via /api/verify-godmode.
# Never put the real value in js/config.js!
GODMODE_PASSCODE=your-secret-passcode-here
